# Point the local first-pass classifier at the M3 Max MLX server instead of the hetzner CPU box.
# classify_daemon.py already speaks /v1/chat/completions, so no code change is needed.
#   source ingest/.mlx.env && python3 ingest/classify_daemon.py
AIPI_OLLAMA_URL=http://127.0.0.1:8848
AIPI_QWEN_MODEL=mlx-community/Qwen3-30B-A3B-4bit
AIPI_NO_THINK=1        # Qwen3 is a reasoning model; without this it returns empty content
AIPI_MAX_TOKENS=160
